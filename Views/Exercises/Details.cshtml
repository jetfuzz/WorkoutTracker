@model WorkoutTracker.Models.ExerciseDetailsVM

@{
    ViewData["Title"] = "Details";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">Exercise</h3>
            </div>
            
            <div class="card pt-4 px-4 border-0 mb-4">
                <h3 class="fw-bold fs-4 mb-3">@Html.DisplayFor(model => model.Exercise.Name)</h3>
                <p><span class="text-secondary">Primary Muscle Group:</span> <span>@Html.DisplayFor(model => model.Exercise.MuscleGroup.Name)</span></p>
            </div>

            <div class="card pt-4 px-4 border-0  mb-4">
                <h3 class="fw-bold fs-4 mb-3">Statistics</h3>
                <select class="form-control">
                    <option value="value">All Time</option>
                </select>

                <canvas id="myChart" class="mb-4"></canvas>
            </div>
            <div class="d-flex mb-3 gap-2">
                <a class="btn btn-secondary" asp-action="Index">Back to List</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let ctx = document.getElementById("myChart");
        const workoutData = @Json.Serialize(Model.WorkoutData)
        console.log(workoutData)

        new Chart(ctx , {
            type: 'line',
            data: {
            labels: workoutData.map(item => new Date(item.date).toLocaleDateString("en-US", 
                {year: "numeric", month: "short", day: "numeric"})),
            datasets: [{
                label: 'Heaviest Weight',
                data: workoutData.map(item => item.highestWeight),
                borderWidth: 1
            }]
            },
            options: {
            scales: {
                x: {
                    ticks: {
                        autoSkip: true,
                        maxTicksLimit: 7
                    }
                },
                y: {
                beginAtZero: false
                }
            }
            }
        });
    </script>
}