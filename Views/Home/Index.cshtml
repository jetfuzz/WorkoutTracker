
@{
    ViewData["Title"] = "Home Page";
}

<section class="py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Track Your Fitness Journey</h1>
        <p class="text-muted mt-3">
            Log exercises, track your sets, reps, and weights fast and easy.
        </p>

        <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-dark px-4">Join Us</a>
            <a asp-controller="Workouts" asp-action="Create" class="btn btn-dark px-4">Start Workout</a>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-5">
                <h2 class="fw-bold">Exercise Progression</h2>
                <p class="text-muted">Monitor your growth over time.</p>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm border-0 h-100 p-3" style="background-color:#111827; border-radius:18px;">
                    <h5 class="fw-bold text-white">Reps Progress</h5>
                    <small class="text-light d-block mb-3">Reps by workout date</small>

                    <canvas id="myChart" class="mb-4"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-5">
                <h2 class="fw-bold">Log Your Workouts</h2>
                <p class="text-muted">Easily log exercises with sets, reps, and weights.</p>
                <a asp-controller="Workouts" asp-action="Create" class="btn btn-dark mt-2">Log New Workout</a>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm border-0 p-3 d-flex flex-row gap-3 align-items-start">
                    <div class="bg-light rounded" style="width:50px; height:50px;"></div>
                    <div>
                        <h5 class="fw-bold">How to Log Your Workouts</h5>
                        <p class="text-muted mb-0">
                            Select your exercise, input sets, reps, and weight to keep track of your progress.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let ctx = document.getElementById("myChart");

        const repLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepLabels ?? new List<string>()));
        const repData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepData ?? new List<int>()));

        new Chart(ctx , {
            type: 'line',
            data: {
                labels: repLabels,
                datasets: [{
                    label: 'Reps',
                    data: repData,
                    borderWidth: 2,
                    tension: 0.3
                }]
            },
            options: {
                scales: {
                    x: {
                        ticks: {
                            autoSkip: true,
                            maxTicksLimit: 7
                        }
                    },
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}