@model IEnumerable<WorkoutTracker.Models.Workout>

@{
    ViewData["Title"] = "Workout History";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Workout History</h2>
        <a class="btn btn-dark px-4" asp-action="Create">New Workout</a>
    </div>
    <div class="row g-4">
        @foreach (var workout in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius:16px;"> 
                    <a asp-action="Details" asp-route-id="@workout.Id" class="stretched-link"></a>
                    <p class="fw-bold mb-0">Username</p>
                    <p class="text-muted small mb-1">@workout.Date.ToString("MMMM dd, yyyy")</p>
                    <p class="fw-bold fs-5 mb-2">@workout.Name</p>
                    <hr />

                    @* only display first 3 exercises per result *@
                    @if (workout.WorkoutExercises.Count() > 3)
                    {
                        @foreach (var workoutExercise in workout.WorkoutExercises.Take(3))
                        {
                            <p class="mb-1">
                                @workoutExercise.Sets.Count sets @workoutExercise.Exercise.Name
                            </p>
                        }
                        <p class="text-muted small">
                            +@(workout.WorkoutExercises.Count() - 3) more exercises
                        </p>
                    }
                    else
                    {
                        @foreach (var workoutExercise in workout.WorkoutExercises)
                        {
                            <p class="mb-1">
                                @workoutExercise.Sets.Count sets @workoutExercise.Exercise.Name
                            </p>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>