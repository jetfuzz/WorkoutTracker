@using System.Security.Claims
@model IEnumerable<WorkoutTracker.Models.Workout>

@{
    ViewData["Title"] = "Workout History";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">Workout History</h3>
                <a class="btn btn-primary" asp-action="Create">New Workout</a>
            </div>

            @foreach (var workout in Model)
            {
                <div class="card px-4 pt-4 border-light-subtle m-3 rounded-3">
                    <a asp-action="Details" asp-route-id="@workout.Id" class="stretched-link"></a>
                    <p class="fw-bold fs-5 mb-1">@workout.Name</p>
                    <p class="text-muted small mb-2">@workout.Date.ToString("MMMM dd, yyyy")</p>

                    <div class="d-flex">
                        <div class="me-4">
                            <p class="text-muted small mb-0">Volume</p>
                            @{
                                var workoutVolume = 0;
                                foreach (var workoutExercise in workout.WorkoutExercises)
                                {
                                    foreach (var set in workoutExercise.Sets)
                                    {
                                        workoutVolume += (int)(set.Repetitions * set.Weight);
                                    }
                                }
                            }
                            <p>@workoutVolume lbs</p>
                        </div>

                        <div>
                            <p class="text-muted small mb-0">Sets</p>
                            @{
                                var setCount = 0;
                                @foreach (var workoutExercise in workout.WorkoutExercises)
                                {
                                    setCount += workoutExercise.Sets.Count();
                                }
                            }
                            <p>@setCount</p>
                        </div>
                    </div>
                    <hr class="text-secondary" />

                    @* only display first 3 exercises per result  *@
                    @if (workout.WorkoutExercises.Count() > 3)
                    {
                        @foreach (var workoutExercise in workout.WorkoutExercises.Take(3))
                        {
                            <p>@workoutExercise.Sets.Count sets @workoutExercise.Exercise.Name</p>
                        }
                        <p class="text-secondary small">see @(workout.WorkoutExercises.Count() - 3) more exercises</p>
                    } else 
                    {
                        @foreach (var workoutExercise in workout.WorkoutExercises)
                        {
                            <p>@workoutExercise.Sets.Count sets @workoutExercise.Exercise.Name</p>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>


