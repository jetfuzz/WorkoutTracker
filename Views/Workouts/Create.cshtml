@model WorkoutTracker.Models.WorkoutCreateVM

@{
    ViewData["Title"] = "Create Workout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">
            <div class="d-flex mb-3">
                <h4 class="fw-semibold">Create Workout</h4>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Leg Day" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Date" class="control-label"></label>
                    <input asp-for="Date" type="date" class="form-control" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>
                <hr />
                <h4>Exercises</h4>

                <div id="exerciseContainer">
                </div>

                <div class="form-group">
                    <button type="button" id="addExerciseBtn" class="btn btn-primary w-100">+ Add Exercise</button>
                </div>
                <hr />
                <div class="form-group d-flex gap-2">
                    <input type="submit" value="Create" class="btn btn-primary w-50" />
                    <input type="button" value="Cancel" class="btn btn-secondary w-50" onclick="location.href='@Url.Action("Index")';" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let exerciseIndex = 0;
        const addExerciseBtn = document.getElementById("addExerciseBtn");
        let exerciseContainer = document.getElementById("exerciseContainer");

        function createExerciseDiv(container) {
            let newExerciseDiv = document.createElement("div");
            newExerciseDiv.id = `exercise.${exerciseIndex}`;
            newExerciseDiv.classList.add("exerciseDiv", "p-3", "mb-4", "card");
            newExerciseDiv.innerHTML = `
                <div class="form-group">
                    <div class="d-flex gap-2 mb-3 align-items-center">
                        <select name="Exercises[${exerciseIndex}].ExerciseId" class="form-control">
                            @foreach (var exercise in Model.ExerciseSelectList)
                            {
                                            <option value="@exercise.Value">@exercise.Text</option>
                            }
                        </select>
                        <button type="button" class="btn-close removeExerciseBtn"></button>
                    </div>
                </div>

                <div class="form-group setDiv">
                    <div class="row  mb-1 text-secondary"  style="font-size: 0.75rem;">
                        <label class="col-2 control-label small text-center">SET</label>
                        <label class="col-4 control-label small text-center">LBS</label>
                        <label class="col-4 control-label small text-center">REPS</label>
                        <div class="col-2"></div>
                    </div>
                </div>
                <button type="button" class="btn w-100 addSetBtn">+ Add Set</button>
            `;
            container.appendChild(newExerciseDiv);
            createSetDiv(newExerciseDiv, exerciseIndex);
            exerciseIndex++;
        }

        function createSetDiv(container, exIndex) {
            //calculate setNumber and setIndex based on current total amount of sets in the exerciseDiv
            let setIndex = container.querySelectorAll(".setRow").length;
            let setNumber = setIndex + 1;
            let setContainer = container.querySelector(".setDiv");

            let newSetDiv = document.createElement("div");
            newSetDiv.classList.add("setRow", "mb-2", "align-items-center");
            newSetDiv.innerHTML = `
                <div class="row justify-content-center align-items-center">
                    <div class="col-2">
                        <input class="form-control form-control-sm text-center  fw-bold"
                        readonly type="number"
                        disabled
                        name="Exercises[${exIndex}].Sets[${setIndex}].SetNumber"
                        value="${setNumber}" />
                    </div>
                    <div class="col-4">
                        <input class="form-control form-control-sm text-center"
                        type="number"
                        required
                        name="Exercises[${exIndex}].Sets[${setIndex}].Weight"
                        min="0" />
                    </div>
                    <div class="col-4">
                        <input class="col-4 form-control form-control-sm text-center"
                        type="number"
                        required
                        name="Exercises[${exIndex}].Sets[${setIndex}].Repetitions"
                        min="1"/>
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn-close removeSetBtn"></button>
                    </div>
                </div>
            `;
            setContainer.appendChild(newSetDiv);
            setIndex++;
        }

        function renumberExerciseIndex() {
            let exerciseDivs = exerciseContainer.querySelectorAll(".exerciseDiv");
            exerciseDivs.forEach((exerciseDiv, index) => {
                exerciseDiv.id = `exercise.${index}`;
                let selectInput = exerciseDiv.querySelector("select");
                selectInput.name = `Exercises[${index}].ExerciseId`;
                //renumber set inputs
                let setRows = exerciseDiv.querySelectorAll(".setRow");
                setRows.forEach((setRow, setIndex) => {
                    let setNumberInput = setRow.querySelector("input[name$='.SetNumber']");
                    setNumberInput.name = `Exercises[${index}].Sets[${setIndex}].SetNumber`;
                    let weightInput = setRow.querySelector("input[name$='.Weight']");
                    weightInput.name = `Exercises[${index}].Sets[${setIndex}].Weight`;
                    let repsInput = setRow.querySelector("input[name$='.Repetitions']");
                    repsInput.name = `Exercises[${index}].Sets[${setIndex}].Repetitions`;
                });
            });
        }

        function renumberSets() {
            let exerciseDivs = document.querySelectorAll(".exerciseDiv");
            exerciseDivs.forEach((exerciseDiv) => {
                let setRows = exerciseDiv.querySelectorAll(".setRow");
                setRows.forEach((setRow, index) => {
                    let setNumberInput = setRow.querySelector("input[name$='.SetNumber']");
                    console.log(setNumberInput);
                    setNumberInput.value = index + 1;
                    //also renumber set index
                    let exerciseDiv = setRow.closest(".exerciseDiv");
                    let exIndex = parseInt(exerciseDiv.id.split(".")[1]);
                    setNumberInput.name = `Exercises[${exIndex}].Sets[${index}].SetNumber`;
                    let weightInput = setRow.querySelector("input[name$='.Weight']");
                    weightInput.name = `Exercises[${exIndex}].Sets[${index}].Weight`;
                    let repsInput = setRow.querySelector("input[name$='.Repetitions']");
                    repsInput.name = `Exercises[${exIndex}].Sets[${index}].Repetitions`;
                });
            });
        }

        addExerciseBtn.addEventListener("click", () => {
            createExerciseDiv(exerciseContainer);
        })

        exerciseContainer.addEventListener("click", (e) => {
            if (e.target.closest(".removeSetBtn")) {
                //remove set and renumber sets
                let setRow = e.target.closest(".setRow");
                let setContainer = setRow.parentElement;
                setContainer.removeChild(setRow);
                renumberSets();
            } if (e.target.closest(".addSetBtn")) {
                //add set
                let exerciseDiv = e.target.closest(".exerciseDiv");
                let exIndex = parseInt(exerciseDiv.id.split(".")[1]);
                createSetDiv(exerciseDiv, exIndex);
            } if (e.target.closest(".removeExerciseBtn")) {
                //remove exercise and renumber exercises
                let exerciseDiv = e.target.closest(".exerciseDiv");
                exerciseContainer.removeChild(exerciseDiv);
                renumberExerciseIndex();
            }
        });

        window.addEventListener("load", (e) => {
            createExerciseDiv(exerciseContainer);
        });
    </script>
}